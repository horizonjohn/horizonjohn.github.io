<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    {% assign visible_news_count = site.announcements.limit | default: 3 %}
    {% assign news_scrollable = false %}
    {% if include.limit and site.announcements.scrollable and news_size > visible_news_count %}
      {% assign news_scrollable = true %}
    {% endif %}
    <div
      class="table-responsive"
      {% if news_scrollable %}
        style="max-height: 10rem; overflow-y: auto"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if news_scrollable %}
          {% assign news_limit = news_size %}
        {% elsif include.limit and site.announcements.limit %}
          {% assign news_limit = site.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr>
            <th scope="row" style="width: 15%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
